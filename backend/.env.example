# ============================================================
# ChessDB Backend — 环境变量配置
# ============================================================
# 本地开发: 复制此文件为 .env 并修改
# 生产部署 (Render): 在 Render Dashboard 中配置这些变量
# ============================================================

# --- Flask ---
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# --- 数据库 ---
# 本地 SQLite (默认)
# DATABASE_URI=sqlite:///chessdb.db
#
# 本地 MySQL
# DATABASE_URI=mysql+pymysql://root:password@localhost/chessdb_dev?charset=utf8mb4
#
# 生产 Neon PostgreSQL (在 Render Dashboard 设置 DATABASE_URL)
# 格式: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/chessdb?sslmode=require
# DATABASE_URL=postgresql://...

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key-here

# --- Stockfish ---
# 留空自动检测；或手动指定 stockfish 二进制文件完整路径
STOCKFISH_PATH=
ANALYSIS_DEPTH=20
ANALYSIS_TIMEOUT=300
ANALYSIS_THREADS=1
ANALYSIS_HASH=256

# --- CORS ---
# 本地: * (允许所有)
# 生产: Vercel 前端域名 (如 https://chessdb.vercel.app)
CORS_ORIGINS=*

# --- 前端地址 (用于后端首页跳转) ---
# 本地: http://localhost:3000
# 生产: Vercel 域名
FRONTEND_ORIGIN=http://localhost:3000

# --- 文件上传 ---
UPLOAD_FOLDER=./uploads
