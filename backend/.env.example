# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Database
DATABASE_URI=mysql+pymysql://root:password@localhost/chessdb_dev?charset=utf8mb4

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here

# Stockfish
# Leave empty to auto-detect, or set to full path of stockfish binary
STOCKFISH_PATH=
ANALYSIS_DEPTH=20
ANALYSIS_TIMEOUT=300
ANALYSIS_THREADS=1
ANALYSIS_HASH=256

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Upload
UPLOAD_FOLDER=./uploads
